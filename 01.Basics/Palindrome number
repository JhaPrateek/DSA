
 public boolean isPalindrome(int x) {
        int a=x;
        if(x<0){
            return false;
        }
        int digit=0;
        while(x!=0){
            digit=(digit*10)+(x%10);
            x/=10;
        }
        if(digit==a){
            return true;
        }
        return false;
    }
