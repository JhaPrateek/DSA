Reverse integer

  public int reverse(int x) {
        long digit =0;
        boolean neg=false;
        if(x<0){
            neg=true;
            x*=(-1);
        }
        while(x>0){
            digit=(digit*10)+(x%10);
            x/=10;
        }
        if(digit>Integer.MAX_VALUE || digit<Integer.MIN_VALUE){
            return 0;
        }
        return neg ? (int)(-1*digit) : (int)(digit);
    }
